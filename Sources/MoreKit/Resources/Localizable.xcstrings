    "specifications.thirdParty.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We extend our heartfelt appreciation to all developers of open-source projects."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此向所有开源项目开发者表达感谢与敬意。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在此向所有開源項目開發者表達感謝與敬意。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在此向所有開源項目開發者表達感謝與敬意。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نعبر عن امتناننا لجميع مطوري المشاريع مفتوحة المصدر"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unser herzlicher Dank gilt allen Entwicklern von Open-Source-Projekten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agradecemos de corazón a todos los desarrolladores de proyectos de código abierto."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Agradecemos de corazón a todos los desarrolladores de proyectos de código abierto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous adressons notre sincère gratitude à tous les développeurs de projets open source."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Estendiamo il nostro sincero apprezzamento a tutti gli sviluppatori di progetti open source."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オープンソースプロジェクトの開発者に心からの感謝を捧げます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오픈소스 프로젝트 개발자 여러분께 진심으로 감사드립니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estendemos nosso sincero agradecimento a todos os desenvolvedores de projetos de código aberto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Estendemos o nosso sincero agradecimento a todos os desenvolvedores de projetos de código aberto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы выражаем сердечную благодарность всем разработчикам проектов с открытым исходным кодом."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Висловлюємо щиру подяку всім розробникам проєктів з відкритим кодом."
          }
        }
      }
    },
